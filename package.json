{
  "name": "atlas",
  "version": "1.0.0",
  "description": "Personal knowledge repository containing blogs, notes, learning, and projects.",
  "scripts": {
    "format": "prettier --write .",
    "lint": "markdownlint **/*.md",
    "link-check": "node scripts/link-check.js",
    "validate-blogs": "node scripts/validate-blog.js",
    "prepare": "husky",
    "validate": "yarn format && yarn lint && yarn link-check && yarn validate-blogs"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli": "^0.49.0",
    "prettier": "^3.9.3"
  },
  "lint-staged": {
    "*.md": [
      "prettier --write",
      "markdownlint",
      "node scripts/link-check.js"
    ],
    "blogs/**/*.md": [
      "node scripts/validate-blog.js"
    ]
  }
}
